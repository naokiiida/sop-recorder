{
  "name": "sop-recorder",
  "version": "1.0.0",
  "description": "Chrome extension that records browser interactions and produces documented SOPs with annotated screenshots.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "size": "size-limit",
    "typecheck": "tsc --noEmit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@webext-core/fake-browser": "^1.3.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.0.0",
    "prettier": "^3.8.1",
    "size-limit": "^12.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0",
    "wxt": "^0.20.20"
  },
  "dependencies": {
    "@picocss/pico": "^2.1.1",
    "jszip": "^3.10.1",
    "lit": "^3.3.2",
    "lucide": "^0.577.0"
  }
}
